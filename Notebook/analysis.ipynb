#Import libries
import pandas as pd
import matplotlib.pyplot as plt

pd.options.display.float_format = '{:.0f}'.format

path="/content/drive/MyDrive/500000 Sales Records.csv"
df=pd.read_csv(path,encoding="utf-8")
df.info()

#Identify top 5 performing countries based on total revenue
top_Country=df.groupby("Country")["Total Revenue"].sum().sort_values(ascending=False).head(5)
plt.bar(top_Country.index,top_Country.values)
plt.title("Top 5 Revenue Country")
plt.ylabel("Revenue")
plt.xlabel("Country")
plt.show()
